{
  "name": "@sajjadbzn/jcell",
  "version": "1.3.0",
  "description": "Lightweight, type-safe JSON-file database + ORM for TypeScript — zero setup, full TypeScript inference, works on Node, Bun & Cloudflare Workers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./d1": {
      "import": "./dist/d1.js",
      "types": "./dist/d1.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bun build ./src/d1.ts --outdir ./dist --target bun && bunx tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "publish": "npm publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "database",
    "json",
    "orm",
    "typescript",
    "bun",
    "node",
    "file-based",
    "embedded"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sajjadbzrn/jcell.git"
  },
  "bugs": {
    "url": "https://github.com/sajjadbzrn/jcell/issues"
  },
  "homepage": "https://github.com/sajjadbzrn/jcell",
  "license": "MIT"
}
